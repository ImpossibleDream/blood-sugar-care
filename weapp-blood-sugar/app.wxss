/* ==========================================================
   血糖数据监测系统 · 全局样式
   视觉设计源自 blood_sugar_dashboard.html
   暖色编辑风 · 数据新闻质感
   作品集演示标注：本套视觉系统为个人作品集展示用途
   ========================================================== */

page {
  --bg-page: #f5f2ec;
  --bg-card: #ffffff;
  --bg-subtle: #edebe6;
  --bg-hover: #f0eee8;
  --text-primary: #1d1b1b;
  --text-secondary: #6b6864;
  --text-muted: #9a9690;
  --accent-gold: #c49a3c;
  --accent-teal: #4a7c7c;
  --alert-red: #c44a4a;
  --alert-amber: #c49a3c;
  --alert-green: #3d8a6a;
  --border-light: rgba(29,27,27,0.07);
  --border-med: rgba(29,27,27,0.12);
  --shadow-card: 0 2rpx 12rpx rgba(29,27,27,0.05);
  --shadow-hover: 0 6rpx 28rpx rgba(29,27,27,0.09);
  --radius-sm: 4rpx;
  --radius-md: 8rpx;
  --radius-lg: 12rpx;
  --transition: 0.25s cubic-bezier(0.22,1,0.36,1);
  background-color: var(--bg-page);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", "Microsoft YaHei", sans-serif;
  color: var(--text-primary);
  -webkit-font-smoothing: antialiased;
  box-sizing: border-box;
  font-size: 28rpx;
  height: 100vh;
  overflow: hidden;
}

/* ---- 标准页面布局 ---- */
.app-page { display: flex; flex-direction: column; height: 100vh; overflow: hidden; }
.app-header {
  flex-shrink: 0;
  background: rgba(255,255,255,0.92);
  border-bottom: 1rpx solid var(--border-light);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  z-index: 10;
  padding: 0 28rpx 14rpx;
}
.app-header .title { font-size: 36rpx; font-weight: 600; letter-spacing: 0.01em; color: var(--text-primary); line-height: 1.3; }
.app-header .sub { font-size: 22rpx; color: var(--text-muted); margin-top: 4rpx; letter-spacing: 0.01em; }
.app-content {
  flex: 1;
  overflow-y: scroll;
  -webkit-overflow-scrolling: touch;
  padding: 0 28rpx;
}

/* ---- 通用卡片 / KPI / 表格组件（匹配原 HTML CSS） ---- */
.kpi-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10rpx; margin-bottom: 18rpx; }
.kpi-card { box-sizing: border-box; background: #ffffff; border-radius: 8rpx; padding: 14rpx 16rpx; box-shadow: var(--shadow-card); border: 1rpx solid var(--border-light); }
.kpi-card .lab { font-size: 20rpx; font-weight: 500; letter-spacing: 0.05em; color: var(--text-muted); margin-bottom: 4rpx; }
.kpi-card .val { font-size: 40rpx; font-weight: 600; color: var(--text-primary); line-height: 1.2; }
.kpi-card .chg { font-size: 20rpx; color: var(--text-muted); margin-top: 4rpx; }

.card { box-sizing: border-box; background: #ffffff; border-radius: 12rpx; padding: 18rpx; box-shadow: var(--shadow-card); display: flex; flex-direction: column; border: 1rpx solid var(--border-light); overflow: hidden; margin-bottom: 20rpx; }
.card .h3 { font-size: 24rpx; font-weight: 600; letter-spacing: 0.03em; color: var(--text-secondary); margin-bottom: 10rpx; flex-shrink: 0; }
.card .ch { display: block; width: 100%; height: 340rpx; flex: none; }
.card .nt {
  font-size: 20rpx; color: var(--text-muted); margin-top: 8rpx;
  padding: 8rpx 12rpx; background: var(--bg-subtle); border-radius: var(--radius-sm);
  border-left: 4rpx solid var(--accent-gold); line-height: 1.5; flex-shrink: 0;
}
.card.fw { grid-column: 1 / -1; }

/* ---- 按钮 ---- */
.btn { display: inline-flex; align-items: center; justify-content: center; padding: 16rpx 32rpx; font-size: 24rpx; font-weight: 500; letter-spacing: 0.03em; border: none; border-radius: var(--radius-sm); }
.btn-primary { background: var(--accent-gold); color: #fff; }
.btn-primary:active { background: #b0882e; }
.btn-outline { background: transparent; color: var(--accent-gold); border: 2rpx solid var(--accent-gold); }
.btn-outline:active { background: var(--accent-gold); color: #fff; }
.btn-sm { padding: 10rpx 24rpx; font-size: 22rpx; }
.btn-danger { background: var(--alert-red); color: #fff; }
.btn-teal { background: var(--accent-teal); color: #fff; }

/* ---- 表格 ---- */
.tbl { width: 100%; border-collapse: collapse; font-size: 24rpx; }
.tbl th { background: var(--bg-subtle); padding: 10rpx; text-align: left; font-weight: 600; font-size: 20rpx; letter-spacing: 0.03em; color: var(--text-secondary); border-bottom: 1rpx solid var(--border-light); }
.tbl td { padding: 10rpx; border-bottom: 1rpx solid var(--border-light); color: var(--text-primary); }

.records-wrap { background: #ffffff; border-radius: 12rpx; padding: 18rpx; box-shadow: var(--shadow-card); border: 1rpx solid var(--border-light); overflow-x: auto; margin-bottom: 20rpx; }
.records-table { width: 100%; border-collapse: collapse; font-size: 24rpx; }
.records-table th { background: var(--bg-subtle); padding: 12rpx 14rpx; text-align: left; font-weight: 600; font-size: 20rpx; letter-spacing: 0.04em; color: var(--text-secondary); border-bottom: 2rpx solid var(--border-med); white-space: nowrap; }
.records-table td { padding: 12rpx 14rpx; border-bottom: 1rpx solid var(--border-light); color: var(--text-primary); }

.pagination { display: flex; gap: 8rpx; align-items: center; justify-content: center; padding: 16rpx; }
.pagination .page-btn { padding: 8rpx 20rpx; font-size: 22rpx; border: 1rpx solid var(--border-med); border-radius: var(--radius-sm); }
.pagination .page-active { background: var(--accent-gold); color: #fff; border-color: var(--accent-gold); }

/* ---- 筛选栏 / 添加表单 ---- */
.filter-bar { display: flex; gap: 10rpx; align-items: center; flex-wrap: wrap; margin-bottom: 14rpx; background: #ffffff; padding: 12rpx 18rpx; border-radius: 12rpx; box-shadow: var(--shadow-card); border: 1rpx solid var(--border-light); }
.filter-bar .filter-label, .add-form .add-label { font-size: 22rpx; font-weight: 500; letter-spacing: 0.02em; color: var(--text-muted); }
.filter-bar .filter-input, .add-form .add-input { padding: 10rpx 14rpx; font-size: 24rpx; border: 1rpx solid var(--border-med); border-radius: var(--radius-sm); background: var(--bg-page); color: var(--text-primary); }

.add-form { display: flex; gap: 10rpx; align-items: center; flex-wrap: wrap; margin-bottom: 14rpx; background: #ffffff; padding: 12rpx 18rpx; border-radius: 12rpx; box-shadow: var(--shadow-card); border: 1rpx solid var(--border-light); }

/* ---- 弹窗 ---- */
.modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(29,27,27,0.45); z-index: 200; display: flex; justify-content: center; align-items: center; backdrop-filter: blur(4rpx); -webkit-backdrop-filter: blur(4rpx); }
.modal-box { background: #ffffff; border-radius: 16rpx; padding: 48rpx; width: 680rpx; max-width: 92vw; max-height: 80vh; overflow-y: auto; box-shadow: 0 16rpx 48rpx rgba(29,27,27,0.2); }
.modal-box .modal-title { font-size: 32rpx; font-weight: 600; margin-bottom: 24rpx; color: var(--text-primary); }
.modal-actions { display: flex; gap: 20rpx; margin-top: 36rpx; }

/* ---- 底部合规文案 ---- */
.footer-legal { text-align: center; font-size: 20rpx; letter-spacing: 0.03em; color: var(--text-muted); padding: 24rpx 32rpx 32rpx; line-height: 1.6; border-top: 2rpx solid var(--border-light); margin-top: 32rpx; }

/* ---- 标签 ---- */
.chart-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 16rpx;
  padding: 12rpx 0 4rpx;
  justify-content: center;
}
.legend-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 6rpx;
  font-size: 20rpx;
  color: #6b6864;
  background: transparent;
  border-radius: 6rpx;
}
.legend-item:active {
  background: rgba(196,154,60,0.1);
}
.legend-color {
  width: 16rpx;
  height: 16rpx;
  min-width: 16rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
  border: 1rpx solid rgba(0,0,0,0.06);
}
.tag-high { color: var(--alert-red); font-weight: 600; font-size: 22rpx; }
.tag-low { color: var(--alert-amber); font-weight: 600; font-size: 22rpx; }
.tag-inj { background: rgba(74,124,124,0.1); padding: 4rpx 14rpx; border-radius: var(--radius-sm); font-size: 20rpx; font-weight: 500; letter-spacing: 0.02em; color: var(--accent-teal); }
.empty-state { text-align: center; padding: 60rpx 0; color: var(--text-muted); font-size: 26rpx; }
.loading-wrap { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; }
.loading-wrap text { font-size: 26rpx; color: var(--text-muted); margin-top: 16rpx; }
.divider { height: 2rpx; background: var(--border-light); margin: 20rpx 0; }

/* ---- 动画 ---- */
@keyframes fadeUp { from { opacity: 0; transform: translateY(12rpx); } to { opacity: 1; transform: translateY(0); } }
.fade-in { animation: fadeUp 0.45s cubic-bezier(0.22,1,0.36,1); }
@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
.spinner { width: 48rpx; height: 48rpx; border: 4rpx solid var(--border-med); border-top-color: var(--accent-gold); border-radius: 50%; animation: spin 0.8s linear infinite; }
/* 作品集演示标注 */
