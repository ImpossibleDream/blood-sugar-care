/* 看板页面样式 - 匹配原 HTML 的 .db-grid / .card / .ch / .nt / .info-col 结构 */
.db-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
  margin-bottom: 14rpx;
}
.db-grid .fw { grid-column: 1 / -1; }

.db-grid .card {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 18rpx;
  box-shadow: 0 2rpx 12rpx rgba(29,27,27,0.05);
  display: flex;
  flex-direction: column;
  border: 1rpx solid rgba(29,27,27,0.07);
  overflow: hidden;
  margin-bottom: 0;
}
.db-grid .card .h3 {
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.03em;
  color: #6b6864;
  margin-bottom: 10rpx;
  flex-shrink: 0;
}
.db-grid .card .ch {
  width: 100%;
  height: 340rpx;
  flex: none;
}
.db-grid .card .nt {
  font-size: 20rpx;
  color: #9a9690;
  margin-top: 8rpx;
  padding: 8rpx 12rpx;
  background: #edebe6;
  border-radius: 4rpx;
  border-left: 4rpx solid #c49a3c;
  line-height: 1.5;
  flex-shrink: 0;
}

/* 右侧信息列 */
.info-col .bx {
  flex: 1;
}
.info-col .bx .h4 {
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
  color: #6b6864;
}
.info-col .bx .p {
  font-size: 20rpx;
  color: #444;
  line-height: 1.5;
}

/* KPI 卡片 */
.kpi-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-bottom: 18rpx;
}
.kpi-card {
  background: #ffffff;
  border-radius: 8rpx;
  padding: 14rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(29,27,27,0.05);
  border: 1rpx solid rgba(29,27,27,0.07);
}
.kpi-card .lab {
  font-size: 20rpx;
  font-weight: 500;
  letter-spacing: 0.05em;
  color: #9a9690;
  margin-bottom: 4rpx;
}
.kpi-card .val {
  font-size: 40rpx;
  font-weight: 600;
  color: #1d1b1b;
  line-height: 1.2;
}
.kpi-card .chg {
  font-size: 20rpx;
  color: #9a9690;
  margin-top: 4rpx;
}

.dashboard-footer {
  text-align: center;
  font-size: 20rpx;
  color: #9a9690;
  padding: 12rpx 0;
  grid-column: 1 / -1;
}
