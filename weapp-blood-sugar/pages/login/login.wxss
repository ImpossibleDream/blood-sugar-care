.login-page {
  min-height: 100vh;
  background: #f5f2ec;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
  position: relative;
  overflow: hidden;
}
.login-bg {
  position: fixed;
  top: -20%;
  right: -15%;
  width: 50%;
  height: 60%;
  background: radial-gradient(ellipse, rgba(196,154,60,0.06) 0%, transparent 70%);
  pointer-events: none;
}
.login-hero {
  margin-top: 120rpx;
  text-align: center;
  z-index: 1;
}
.hero-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}
.hero-title {
  font-size: 44rpx;
  font-weight: 600;
  letter-spacing: 0.01em;
  color: #1d1b1b;
}
.hero-sub {
  font-size: 24rpx;
  color: #9a9690;
  margin-top: 8rpx;
  letter-spacing: 0.01em;
}
.login-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 48rpx 40rpx;
  margin-top: 48rpx;
  width: 100%;
  max-width: 600rpx;
  box-shadow: 0 2rpx 20rpx rgba(29,27,27,0.06);
  border: 1rpx solid rgba(29,27,27,0.07);
  z-index: 1;
}
.mode-tabs {
  display: flex;
  border-bottom: 2rpx solid rgba(29,27,27,0.07);
  margin-bottom: 40rpx;
}
.mode-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  font-weight: 500;
  color: #9a9690;
  border-bottom: 3rpx solid transparent;
  transition: all 0.25s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}
.mode-tab.active {
  color: #c49a3c;
  border-bottom-color: #c49a3c;
}
.mode-icon {
  font-size: 32rpx;
}
.wechat-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}
.wechat-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 12rpx;
  border: 3rpx solid rgba(196,154,60,0.3);
}
.wechat-avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 12rpx;
  border: 3rpx solid rgba(196,154,60,0.3);
  background: #edebe6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}
.wechat-nick {
  font-size: 28rpx;
  color: #6b6864;
}
.login-btn {
  width: 100%;
  padding: 24rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}
.login-tip {
  text-align: center;
  font-size: 20rpx;
  color: #9a9690;
}
.phone-label {
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 0.03em;
  color: #9a9690;
  margin-bottom: 8rpx;
  display: block;
}
.phone-input {
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  border: 2rpx solid rgba(29,27,27,0.12);
  border-radius: 8rpx;
  background: #f5f2ec;
}
.code-row {
  display: flex;
  gap: 16rpx;
  align-items: flex-end;
}
.code-input {
  flex: 1;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  border: 2rpx solid rgba(29,27,27,0.12);
  border-radius: 8rpx;
  background: #f5f2ec;
}
.code-btn {
  min-width: 180rpx;
  height: 72rpx;
  font-size: 24rpx;
}
.btn-disabled {
  background: rgba(29,27,27,0.05);
  color: #9a9690;
  border: 2rpx solid rgba(29,27,27,0.07);
}
.footer-legal {
  text-align: center;
  font-size: 20rpx;
  color: #9a9690;
  padding: 48rpx 0 32rpx;
  line-height: 1.6;
  z-index: 1;
}
