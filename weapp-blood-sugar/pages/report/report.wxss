.db-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
  margin-bottom: 14rpx;
}
.report-stat {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 14rpx;
  width: 100%;
}
.report-stat .kpi-card {
  min-width: 0;
  width: 100%;
}
.report-fields-row {
  display: flex;
  gap: 16rpx;
  align-items: flex-end;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}
.report-btns-row {
  display: flex;
  gap: 16rpx;
  justify-content: center;
}
.report-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.report-field {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.report-label {
  font-size: 20rpx;
  font-weight: 500;
  letter-spacing: 0.02em;
  color: #9a9690;
}
.report-value {
  font-size: 26rpx;
  color: #1d1b1b;
  padding: 12rpx 16rpx;
  background: #f5f2ec;
  border-radius: 4rpx;
  border: 1rpx solid rgba(29,27,27,0.12);
  min-width: 180rpx;
  display: inline-block;
}
.stat-label {
  display: block;
  font-size: 20rpx;
  font-weight: 500;
  letter-spacing: 0.05em;
  color: #9a9690;
  margin-bottom: 4rpx;
}
.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #1d1b1b;
  line-height: 1.2;
}
.recent-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(29,27,27,0.06);
  font-size: 24rpx;
}
.recent-date { width: 180rpx; color: #6b6864; }
.recent-slot { width: 140rpx; color: #6b6864; }
.recent-val { width: 120rpx; font-weight: 600; color: #1d1b1b; }
.tag-high { color: #c44a4a; font-weight: 600; }
.tag-low { color: #c49a3c; font-weight: 600; }
.tag-normal { color: #3d8a6a; }
.tag-inj { color: #4a7c7c; font-weight: 600; }
