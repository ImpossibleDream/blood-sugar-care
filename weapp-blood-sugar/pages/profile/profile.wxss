.profile-page {
}
.profile-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
  background: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(29,27,27,0.05);
  border: 1rpx solid rgba(29,27,27,0.07);
  margin-bottom: 20rpx;
}
.profile-avatar {
  margin-bottom: 16rpx;
}
.avatar-img, .avatar-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(196,154,60,0.3);
}
.avatar-placeholder {
  background: #edebe6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
}
.profile-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1d1b1b;
  margin-bottom: 6rpx;
}
.profile-mode {
  font-size: 24rpx;
  color: #9a9690;
}
.info-list {
  margin-bottom: 32rpx;
}
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(29,27,27,0.06);
}
.info-row:last-child {
  border-bottom: none;
}
.info-key {
  font-size: 26rpx;
  color: #6b6864;
}
.info-val {
  font-size: 26rpx;
  color: #1d1b1b;
  font-weight: 500;
}
.logout-btn {
  width: 100%;
  padding: 20rpx;
  font-size: 28rpx;
  margin-bottom: 40rpx;
  box-sizing: border-box;
}
