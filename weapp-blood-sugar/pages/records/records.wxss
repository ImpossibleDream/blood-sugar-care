.add-form {
  margin-bottom: 20rpx;
}
.add-form.card {
  padding: 20rpx 24rpx;
}
.add-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.add-field {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.add-label {
  font-size: 20rpx;
  font-weight: 500;
  letter-spacing: 0.02em;
  color: #9a9690;
  display: block;
  text-align: left;
}
.add-value, .edit-value {
  font-size: 26rpx;
  color: #1d1b1b;
  padding: 12rpx 16rpx;
  background: #f5f2ec;
  border-radius: 4rpx;
  border: 1rpx solid rgba(29,27,27,0.12);
  min-width: 180rpx;
  display: inline-block;
}
.add-input {
  padding: 12rpx 16rpx;
  font-size: 24rpx;
  border: 1rpx solid rgba(29,27,27,0.12);
  border-radius: 4rpx;
  background: #f5f2ec;
  min-width: 180rpx;
  box-sizing: border-box;
  width: 100%;
}
.add-field .add-value,
.add-field .add-input {
  width: 100%;
  box-sizing: border-box;
}
.add-field .add-value {
  font-size: 24rpx;
  padding: 12rpx 16rpx;
  background: #f5f2ec;
  border-radius: 4rpx;
  border: 1rpx solid rgba(29,27,27,0.12);
  display: inline-block;
  text-align: left;
  min-width: 180rpx;
}
.add-btn {
  width: 100%;
  height: 60rpx;
  padding: 0;
  align-self: flex-end;
  box-sizing: border-box;
}
.export-bar {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.record-count {
  font-size: 22rpx;
  color: #9a9690;
}
.picker-value {
  box-sizing: border-box;
  width: 100%;
  height: 72rpx;
  line-height: 1.4;
  font-size: 28rpx;
  color: #1d1b1b;
  padding: 16rpx 20rpx;
  background: #f5f2ec;
  border-radius: 6rpx;
  border: 2rpx solid rgba(29,27,27,0.12);
  min-width: 240rpx;
  display: block;
  text-align: center;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.form-group {
  margin-bottom: 24rpx;
}
.picker-value:active {
  border-color: #c49a3c;
  box-shadow: 0 0 0 3rpx rgba(196,154,60,0.15);
}
.modal-label {
  font-weight: 700;
  font-size: 24rpx;
  color: #6b6864;
  margin-bottom: 8rpx;
  display: block;
  letter-spacing: 0.03em;
}
.btn-cancel {
  background: transparent;
  color: #6b6864;
  border: 1rpx solid rgba(29,27,27,0.12);
}
.modal-overlay {
  display: none;
}
.modal-overlay.show {
  display: flex;
}
/* 编辑弹窗使用全局 .form-group, .form-label, .form-input, .modal-actions 样式 */
