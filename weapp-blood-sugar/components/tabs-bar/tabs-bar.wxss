.tabs-bar {
  display: flex;
  flex-shrink: 0;
  width: 100%;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  border-top: 1rpx solid rgba(29,27,27,0.07);
  padding-bottom: env(safe-area-inset-bottom);
}
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0;
  position: relative;
}
.tab-item.active .tab-label {
  color: #c49a3c;
}
.tab-item.active::after {
  content: '';
  position: absolute;
  top: 0;
  left: 20%;
  right: 20%;
  height: 3rpx;
  background: #c49a3c;
  border-radius: 0 0 3rpx 3rpx;
}
.tab-icon {
  font-size: 40rpx;
  line-height: 1;
  margin-bottom: 4rpx;
}
.tab-label {
  font-size: 20rpx;
  color: #9a9690;
  font-weight: 500;
  letter-spacing: 0.02em;
  transition: color 0.25s;
}
