.kpi-card {
  background: #ffffff;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(29,27,27,0.05);
  border: 1rpx solid rgba(29,27,27,0.07);
  box-sizing: border-box;
}
.lab {
  font-size: 20rpx;
  font-weight: 500;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: #9a9690;
  margin-bottom: 6rpx;
}
.val {
  font-size: 40rpx;
  font-weight: 600;
  color: #1d1b1b;
  line-height: 1.2;
}
.chg {
  font-size: 20rpx;
  color: #9a9690;
  margin-top: 6rpx;
}
