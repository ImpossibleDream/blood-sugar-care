.card {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx 20rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(29,27,27,0.05);
  border: 1rpx solid rgba(29,27,27,0.07);
  margin-bottom: 20rpx;
  overflow: hidden;
}
.card-title {
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.03em;
  color: #6b6864;
  margin-bottom: 16rpx;
}
.chart-box {
  width: 100%;
  height: 360rpx;
  min-height: 360rpx;
  position: relative;
  overflow: hidden;
}
.chart-canvas {
  width: 100%;
  height: 360rpx;
  min-height: 360rpx;
  overflow: hidden;
}
.card-note {
  font-size: 20rpx;
  color: #9a9690;
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background: #edebe6;
  border-radius: 4rpx;
  border-left: 4rpx solid #c49a3c;
  line-height: 1.5;
}
