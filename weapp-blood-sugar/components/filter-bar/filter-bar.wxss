.filter-bar {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(29,27,27,0.05);
  border: 1rpx solid rgba(29,27,27,0.07);
  margin-bottom: 20rpx;
}
.filter-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.filter-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.filter-item .filter-value {
  width: 100%;
  box-sizing: border-box;
}
.filter-label {
  font-size: 20rpx;
  font-weight: 500;
  letter-spacing: 0.02em;
  color: #9a9690;
}
.filter-value {
  font-size: 24rpx;
  color: #1d1b1b;
  padding: 8rpx 16rpx;
  background: #f5f2ec;
  border-radius: 4rpx;
  border: 1rpx solid rgba(29,27,27,0.12);
  min-width: 160rpx;
  display: inline-block;
}
.filter-row .btn-outline {
  height: 60rpx;
  width: 100%;
  align-self: flex-end;
  box-sizing: border-box;
  padding: 0;
  font-size: 22rpx;
}
